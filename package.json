{
  "name": "ai-case-management-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AI-Powered Case Management Dashboard with OpenAI GPT-3.5-turbo Integration - Modern React 19 application showcasing intelligent AI assistance, context-aware suggestions, and professional frontend development",
  "keywords": [
    "react",
    "vite",
    "tailwindcss",
    "case-management",
    "ai-assistant",
    "openai",
    "gpt-3.5-turbo",
    "framer-motion",
    "recharts",
    "smart-suggestions",
    "context-aware-ai",
    "frontend-portfolio"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx --fix",
    "lint:strict": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0 --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.{js,jsx,css,md}\"",
    "docs:generate": "jsdoc -c jsdoc.config.json",
    "docs:serve": "npx http-server ./docs/generated -p 8080",
    "performance:setup": "node scripts/setup-performance.js",
    "lighthouse": "npx lighthouse http://localhost:3000 --view",
    "lighthouse:ci": "lhci autorun",
    "analyze": "npm run build && npx vite-bundle-analyzer dist/stats.html",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage --run",
    "test:watch": "vitest --watch",
    "test:security": "vitest --run src/utils/__tests__/security.test.js src/context/__tests__/SecureAuthContext.test.jsx src/components/forms/__tests__/SecureLoginForm.test.jsx",
    "test:components": "vitest --run src/components/**/__tests__/*.test.{js,jsx}",
    "test:hooks": "vitest --run src/hooks/**/__tests__/*.test.{js,jsx}",
    "test:utils": "vitest --run src/utils/**/__tests__/*.test.{js,jsx}",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install",
    "build:analyze": "npm run build && npx vite-bundle-analyzer",
    "serve": "npm run build && npm run preview",
    "deploy:vercel": "npm run build && vercel --prod",
    "deploy:netlify": "npm run build && netlify deploy --prod --dir=dist",
    "demo:build": "node scripts/demo-deployment.cjs",
    "demo:screenshots": "node scripts/generate-demo-screenshots.cjs",
    "demo:verify": "npm run build && npm run test:components && npm run demo:screenshots",
    "demo:deploy": "npm run demo:verify && npm run deploy:netlify"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.35.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "openai": "^6.27.0",
    "prop-types": "^15.8.1",
    "puppeteer": "^24.39.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tailwindcss": "^3.4.19",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^28.1.0",
    "msw": "^2.0.11",
    "postcss": "^8.4.32",
    "terser": "^5.46.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
