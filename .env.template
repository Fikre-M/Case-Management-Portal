# Environment Configuration Template
# ⚠️ SECURITY WARNING: Never commit real API keys to version control!
# Copy this to your .env file and replace with your actual keys

# Basic Configuration
VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_NAME=AI Appointment & Case Management
VITE_AI_SERVICE_URL=
VITE_ENABLE_ANALYTICS=false

# API Keys - Replace with your actual keys
VITE_AidFlow_API_KEY=your_gemini_api_key_here
JWT_SECRET=your_jwt_secret_here

# AI Configuration - CRITICAL SETTINGS
VITE_AI_ENABLED=true                    # Must be true for AI
VITE_USE_LOW_COST_MODEL=true            # Keep this true
VITE_USE_MOCK_DATA=false                # MUST be false for real AI
VITE_DEMO_MODE=false                    # MUST be false for real AI

# Testing Instructions:
# 1. Copy this to .env file (already gitignored)
# 2. Replace placeholder values with your actual keys
# 3. Restart development server: npm run dev
# 4. Test at: http://localhost:2018/debug-env.html

# Security Notes:
# - Never commit real API keys
# - Use different keys for development/production
# - Rotate keys regularly
# - Monitor key usage in Google Cloud Console
